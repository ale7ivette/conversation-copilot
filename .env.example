# Copy to .env.local and set your keys (never commit .env.local)
OPENAI_API_KEY=

# Live transcription: openai (default) = OpenAI Realtime; assemblyai = Universal Streaming v3 + speaker labels.
# If you use assemblyai, set the same value for NEXT_PUBLIC_TRANSCRIPTION_PROVIDER so the browser matches the server.
# TRANSCRIPTION_PROVIDER=assemblyai
# NEXT_PUBLIC_TRANSCRIPTION_PROVIDER=assemblyai

# Required when TRANSCRIPTION_PROVIDER=assemblyai (mint short-lived streaming tokens server-side).
# ASSEMBLYAI_API_KEY=

# Optional: Universal Streaming speech model (browser bundle). See AssemblyAI docs.
# NEXT_PUBLIC_ASSEMBLYAI_SPEECH_MODEL=universal-streaming-english

# Optional: max transcript lines kept in memory per session (default 2000). Must be NEXT_PUBLIC for the browser buffer.
# NEXT_PUBLIC_TRANSCRIPT_SESSION_MAX_LINES=2000

# Optional: BCP-47 language hint for Realtime input transcription (e.g. en, es) — OpenAI path only.
TRANSCRIPTION_LANGUAGE=en

# Optional: Realtime input transcription model (org must have access). OpenAI path only.
# Default in code: gpt-4o-mini-transcribe
# For speaker diarization (if enabled on your account): gpt-4o-transcribe-diarize
# REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize

# Optional default Realtime input noise reduction when the client does not pass a preference.
# near_field = headset / close mic; far_field = room / laptop mic.
# REALTIME_INPUT_NOISE_REDUCTION=far_field

# Set to "true" to show the developer testing panel in production builds (default: off).
# NEXT_PUBLIC_COPILOT_DEV_TOOLS=true
