# Copy to .env.local and set your key (never commit .env.local)
OPENAI_API_KEY=

# Optional: BCP-47 language hint for Realtime input transcription (e.g. en, es)
TRANSCRIPTION_LANGUAGE=en

# Optional: Realtime input transcription model (org must have access).
# Default in code: gpt-4o-mini-transcribe
# For speaker diarization (if enabled on your account): gpt-4o-transcribe-diarize
# REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize

# Optional default Realtime input noise reduction when the client does not pass a preference.
# near_field = headset / close mic; far_field = room / laptop mic.
# REALTIME_INPUT_NOISE_REDUCTION=far_field

# Set to "true" to show the developer testing panel in production builds (default: off).
# NEXT_PUBLIC_COPILOT_DEV_TOOLS=true
